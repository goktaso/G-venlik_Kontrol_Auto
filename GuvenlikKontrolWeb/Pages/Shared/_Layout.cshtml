<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "Güvenlik Tur") - GOM</title>

    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>

    <style>
        :root {
            --sidebar-width: 260px;
            --sidebar-gradient: linear-gradient(180deg, #1a2a6c 0%, #2c5364 100%);
        }

        body {
            overflow-x: hidden;
            background-color: #f4f7f6;
            font-family: 'Segoe UI', sans-serif;
        }

        #wrapper {
            display: flex;
            width: 100%;
        }

        /* --- SIDEBAR --- */
        .sidebar {
            width: var(--sidebar-width);
            min-width: var(--sidebar-width);
            min-height: 100vh;
            background: var(--sidebar-gradient);
            color: white;
            box-shadow: 4px 0 15px rgba(0,0,0,0.2);
            transition: all 0.3s;
            z-index: 1050;
            display: flex;
            flex-direction: column;
        }

            .sidebar .nav-link {
                color: rgba(255,255,255,0.7);
                padding: 12px 20px;
                margin: 4px 12px;
                border-radius: 10px;
                text-decoration: none;
                display: block;
                transition: 0.2s;
            }

                .sidebar .nav-link:hover, .sidebar .nav-link.active {
                    background: rgba(255,255,255,0.1);
                    color: #00d2ff !important;
                }

                .sidebar .nav-link.active {
                    background: #00d2ff !important;
                    color: white !important;
                }

        .filter-section {
            padding: 1rem;
            background: rgba(255,255,255,0.08);
            margin: 10px;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.1);
        }

        /* --- İÇERİK --- */
        .content-area {
            flex: 1;
            padding: 2rem;
            width: 100%;
            min-width: 0;
        }

        .mobile-top-bar {
            display: none;
            background: #1a2a6c;
            color: white;
            padding: 10px 15px;
            position: sticky;
            top: 0;
            z-index: 1100;
        }

        @@media (max-width: 992px) {
            .mobile-top-bar

        {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .sidebar {
            position: fixed;
            left: -260px;
        }

        #wrapper.toggled .sidebar {
            left: 0;
        }

        .content-area {
            padding: 1rem;
        }

        }

        @@media print {
            .no-print

        {
            display: none !important;
        }

        .content-area {
            padding: 0 !important;
            margin: 0 !important;
        }

        }
    </style>
</head>
<body>

    <div class="mobile-top-bar shadow no-print">
        <button class="btn btn-outline-light btn-sm" id="menu-toggle"><i class="bi bi-list fs-3"></i></button>
        <span class="fw-bold">GOM YÖNETİM</span>
        <div style="width: 40px;"></div>
    </div>

    <div class="d-flex" id="wrapper">
        <div class="sidebar border-end shadow no-print">
            <div class="p-4 border-bottom text-center">
                <h5 class="m-0 fw-bold" style="color: #00d2ff;">GÜVENLİK TUR</h5>
                @if (User.Identity.IsAuthenticated)
                {
                    <div class="mt-2 small text-white-50">
                        <i class="bi bi-person-circle text-info"></i> @User.Identity.Name
                        <br />
                        <span class="badge bg-dark mt-1">@User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value</span>
                    </div>
                }
            </div>

            <ul class="nav flex-column mb-3 mt-3">
                @if (User.Identity.IsAuthenticated)
                {
                    <li><a class="nav-link" href="/Index"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a></li>
                    <li><a class="nav-link" href="/TurAnaliz"><i class="bi bi-search me-2"></i> Tur Analizi</a></li>
                    <li><a class="nav-link" href="/EksikNokta"><i class="bi bi-exclamation-triangle me-2"></i> Eksik Nokta</a></li>

                    <!-- YENİ EKLENEN BUTON -->
                    <li><a class="nav-link" href="/MukerrerNoktalar"><i class="bi bi-layers-half me-2"></i> Mükerrer Kayıt</a></li>

                    <li><a class="nav-link" href="/GunlukTur"><i class="bi bi-calendar3 me-2"></i> Günlük Tur</a></li>
                    <li><a class="nav-link" href="/BekciPerformans"><i class="bi bi-star me-2"></i> Bekçi Performansı</a></li>
                    <li><a class="nav-link" href="/AtilmayanTur"><i class="bi bi-calendar-x me-2"></i> Atılmayan Tur</a></li>

                    @if (User.IsInRole("Admin"))
                    {
                        <li><a class="nav-link text-warning" href="/KullaniciYonetimi"><i class="bi bi-people-fill me-2"></i> Kullanıcılar</a></li>
                    }
                }
            </ul>

            @if (User.Identity.IsAuthenticated)
            {
                <div class="filter-section">
                    <h6 class="text-info small fw-bold">ZAMAN ARALIĞI</h6>
                    <input type="datetime-local" id="menuBas" class="form-control form-control-sm mb-2 bg-dark text-white border-0" />
                    <input type="datetime-local" id="menuBit" class="form-control form-control-sm mb-2 bg-dark text-white border-0" />
                    <button type="button" id="btnRapor" onclick="raporuGetir()" class="btn btn-info btn-sm w-100 text-white fw-bold shadow-sm">
                        <i class="bi bi-arrow-repeat me-1"></i> Raporu Güncelle
                    </button>
                </div>

                <div class="filter-section">
                    <h6 class="text-success small fw-bold">SİSTEM</h6>
                    <button onclick="exportAllExcel()" class="btn btn-success btn-sm w-100 mb-2 fw-bold">
                        <i class="bi bi-file-earmark-excel me-2"></i> Excel (.xlsx)
                    </button>
                    <button type="button" onclick="generatePDF()" class="btn btn-danger btn-sm w-100 mb-2 fw-bold">
                        <i class="bi bi-file-earmark-pdf me-2"></i> PDF / Yazdır
                    </button>

                    @if (User.IsInRole("Admin") || User.IsInRole("PowerUser"))
                    {
                        <a href="/VeriYukle" class="btn btn-warning btn-sm w-100 mb-2 fw-bold" style="color: #1a2a6c;">
                            <i class="bi bi-cloud-arrow-up-fill me-2"></i> VERİ YÜKLE
                        </a>
                    }

                    <form method="post" action="/Account/Logout" id="logoutForm">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger btn-sm w-100 fw-bold">
                            <i class="bi bi-box-arrow-right me-2"></i> ÇIKIŞ YAP
                        </button>
                    </form>

                    <div class="mt-4 pt-3 border-top border-secondary text-center no-print">
                        <img src="/images/unlu-logo.png?v=@DateTime.Now.Ticks"
                             alt="Şirket Logosu"
                             style="max-width: 150px; max-height: 80px; object-fit: contain; filter: drop-shadow(0px 2px 4px rgba(0,0,0,0.5));"
                             onerror="this.src='/images/default-logo.png';">
                        <div class="mt-2 small text-white-50" style="font-size: 0.65rem; letter-spacing: 1px; text-transform: uppercase;">
                            GOM DENETİM SİSTEMİ
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="content-area">
            @RenderBody()
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

    <script>
        $(document).ready(function() {
            $("#menu-toggle").click(function(e) {
                e.stopPropagation();
                $("#wrapper").toggleClass("toggled");
            });

            const path = window.location.pathname;
            $('.sidebar .nav-link').each(function() {
                if ($(this).attr('href') === path) $(this).addClass('active');
            });

            $("#menuBas").val(localStorage.getItem("baslangic"));
            $("#menuBit").val(localStorage.getItem("bitis"));
        });

        function raporuGetir() {
            const bas = $("#menuBas").val();
            const bit = $("#menuBit").val();

            if (!bas || !bit) return alert("Lütfen tarih seçiniz!");

            if (bas === localStorage.getItem("baslangic") && bit === localStorage.getItem("bitis")) {
                console.log("Tarihler aynı, tazeleme gerekmiyor.");
                return;
            }

            $("#btnRapor").prop('disabled', true).text("Yükleniyor...");

            localStorage.setItem("baslangic", bas);
            localStorage.setItem("bitis", bit);
            sessionStorage.setItem("baslangic", bas);
            sessionStorage.setItem("bitis", bit);

            sessionStorage.removeItem("turData");
            sessionStorage.removeItem("performansData");

            window.location.href = window.location.pathname;
        }

        function exportAllExcel() {
            let tables = document.querySelectorAll("table");
            if (tables.length === 0) return alert("Tablo bulunamadı!");
            const wb = XLSX.utils.book_new();
            tables.forEach((table, index) => {
                const ws = XLSX.utils.table_to_sheet(table);
                XLSX.utils.book_append_sheet(wb, ws, "Rapor " + (index + 1));
            });
            XLSX.writeFile(wb, `GOM_Rapor_${new Date().toLocaleDateString('tr-TR')}.xlsx`);
        }

        function generatePDF() {
            const element = document.querySelector(".content-area");
            if (!element) return alert("İçerik bulunamadı!");

            const opt = {
                margin: [5, 5, 5, 5],
                filename: `GOM_Rapor_${new Date().toLocaleDateString('tr-TR')}.pdf`,
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2, useCORS: true, letterRendering: true, windowWidth: 1400 },
                jsPDF: { unit: 'mm', format: 'a4', orientation: 'landscape' }
            };

            const buttons = document.querySelectorAll(".btn, .btn-group, .filter-section, .alert, .no-print");
            buttons.forEach(b => b.style.display = "none");

            const originalZoom = element.style.zoom;
            element.style.zoom = "0.8";

            html2pdf().set(opt).from(element).save().then(() => {
                buttons.forEach(b => b.style.display = "");
                element.style.zoom = originalZoom || "1";
            });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>